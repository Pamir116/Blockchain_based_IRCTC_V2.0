# ── REQUIRED ─────────────────────────────────────────────────────
# MetaMask deployer private key (NEVER commit real key!)
PRIVATE_KEY=your_metamask_private_key_here

# ── BLOCKCHAIN ────────────────────────────────────────────────────
# For local:  leave as default (hardhat node uses 8545)
# For Amoy:   https://rpc-amoy.polygon.technology
# For Mumbai: https://rpc-mumbai.maticvigil.com
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# ── BACKEND ───────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/irctc-blockchain
PORT=5000
BACKEND_URL=http://localhost:5000

# KYC salt — change this in production!
KYC_SALT=irctc_blockchain_change_me_production

# ── DIGILOCKER (optional — mock used in dev) ──────────────────────
# Apply at: https://developer.digilocker.gov.in
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in

# ── FRONTEND ──────────────────────────────────────────────────────
REACT_APP_BACKEND_URL=http://localhost:5000
